# ============================================
# OpenClaw Dashboard — Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values
# Only OPENCLAW_HOME is required — everything else has defaults

# --- Required ---

# Path to your OpenClaw data directory (usually ~/.openclaw)
OPENCLAW_HOME=~/.openclaw

# --- Optional: OpenClaw Integration ---

# Path to the openclaw CLI binary (auto-detected if on PATH)
# OPENCLAW_BIN=/opt/homebrew/bin/openclaw

# OpenClaw gateway port (default: 18789)
# OPENCLAW_GATEWAY_PORT=18789

# Gateway authentication token (auto-read from ~/.openclaw/secrets/.env if not set)
# OPENCLAW_GATEWAY_TOKEN=

# --- Optional: Project Integration ---

# Path to your project repository (enables sprint/task parsing)
# PROJECT_REPO_PATH=~/my-project

# GitHub personal access token (enables GitHub integration)
# GITHUB_PAT=

# --- Optional: AI Features ---

# Product context for competitor research (describe your product)
# COMPETITOR_PRODUCT_CONTEXT=A developer tool that helps teams manage AI agents

# --- Optional: Voice Features ---

# ElevenLabs API key (enables text-to-speech for agents)
# ELEVENLABS_API_KEY=

# --- Dashboard Configuration ---

# SQLite database directory (default: ~/.openclaw-dashboard)
# DATA_DIR=~/.openclaw-dashboard

# Server port (default: 3333)
# PORT=3333

# --- Telemetry ---

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
