# ===================
# OpenClaw Dashboard — Environment Configuration
# ===================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# GitHub Personal Access Token (optional — for private repo sync)
GITHUB_PAT=

# ===================
# Data Directories
# ===================

# OpenClaw data directory (default: ~/.openclaw)
OPENCLAW_HOME=~/.openclaw

# Project repo path (optional — enables sprint/task parsing from markdown)
# PROJECT_REPO_PATH=~/my-project

# SQLite data directory (default: ~/.openclaw-dashboard)
# DATA_DIR=~/.openclaw-dashboard

# ===================
# Gateway
# ===================

# OpenClaw gateway port (default: 18789)
# OPENCLAW_GATEWAY_PORT=18789
